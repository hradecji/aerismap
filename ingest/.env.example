# AerisMap ingest — environment variables
# Provide via CI secrets, your shell, or a local .env file run with
# `pnpm --filter @aerismap/ingest exec tsx --env-file=.env src/run.ts`.
# All are optional locally: with nothing set, the job ingests Sensor.Community
# only and writes artifacts to ./.artifacts (or the directory passed as
# `--out <dir>`). In GitHub Actions (GITHUB_ACTIONS set by the runner) the R2
# credentials are required — the run exits 1 instead of going green while
# uploading nothing.

# OpenAQ v3 API key (free: https://explore.openaq.org/register).
# When unset, the official/reference layer is skipped and the run continues
# with community data only. When set, the /locations registry is cached for
# 24 h as internal/openaq-registry.json (in R2 when configured, else under
# the out dir) to skip the daily-refresh calls on hourly runs.
OPENAQ_API_KEY=

# Cloudflare R2 upload target (S3-compatible API,
# endpoint https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com).
# All three credentials must be set to enable upload; otherwise the run is
# local-only. Use a bucket-scoped R2 API token with object read+write
# permission (read is needed to carry a failed source's stations forward from
# the previous snapshot and for the OpenAQ registry cache).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# R2 bucket name. Optional, defaults to aerismap-data.
R2_BUCKET=
