# AerisMap ingest — environment variables
# Provide via CI secrets, your shell, or a local .env file run with
# `pnpm --filter @aerismap/ingest exec tsx --env-file=.env src/run.ts`.
# All are optional locally: with nothing set, the job ingests Sensor.Community
# only and writes artifacts to ./.artifacts (or the directory passed as
# `--out <dir>`). In GitHub Actions (GITHUB_ACTIONS set by the runner) the
# Cloudflare KV settings are required — the run exits 1 instead of going green
# while uploading nothing.

# OpenAQ v3 API key (free: https://explore.openaq.org/register).
# When unset, the official/reference layer is skipped and the run continues
# with community data only. When set, the /locations registry is cached for
# 24 h as internal/openaq-registry.json (in KV when configured, else under
# the out dir) to skip the daily-refresh calls on hourly runs.
OPENAQ_API_KEY=

# Cloudflare KV upload target (REST API at
# https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/storage/kv/
# namespaces/<NAMESPACE_ID>/values/<key>). All three must be set to enable
# upload; otherwise the run is local-only. Use an API token with the
# "Workers KV Storage: Edit" permission — edit implies read, which the run
# needs to carry a failed source's stations forward from the previous
# snapshot and for the OpenAQ registry cache. The namespace id is the KV
# namespace the worker binds as DATA.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
